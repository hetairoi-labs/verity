{
	"name": "@kex/web",
	"version": "1.0.0",
	"type": "module",
	"main": "server.ts",
	"module": "server.ts",
	"scripts": {
		"dev": "clear && bun push && bun check && bun run --parallel tsr-watch dev:server",
		"dev:server": "bun --hot server.ts",
		"start": "tsr generate && NODE_ENV=production bun --env-file=.env.production run server.ts",
		"deploy": "./lib/scripts/deploy.sh",
		"build": "tsr generate && bun lib/utils/build.ts",
		"tsc": "bunx --bun tsc --noEmit",
		"check": "bunx biome check --write",
		"generate": "bunx drizzle-kit generate",
		"migrate": "bunx drizzle-kit migrate",
		"push": "bunx drizzle-kit push",
		"test": "rm -f test.db && bun --env-file=.env.test run test:inner",
		"test:inner": "bun run push --force && bun test",
		"shadcn": "bunx --bun shadcn@latest add",
		"authenticate": "bun lib/utils/google.ts",
		"tsr-watch": "tsr watch"
	},
	"dependencies": {
		"@google/genai": "^1.39.0",
		"@hono/zod-validator": "^0.7.6",
		"@phosphor-icons/react": "^2.1.10",
		"@privy-io/node": "^0.9.0",
		"@privy-io/react-auth": "^3.13.1",
		"@privy-io/wagmi": "^4.0.1",
		"@tanstack/react-form": "^1.28.0",
		"@tanstack/react-query": "^5.90.20",
		"@tanstack/react-router": "^1.158.0",
		"axios": "^1.13.5",
		"better-sqlite3": "^12.6.2",
		"bun-plugin-tailwind": "^0.1.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.1",
		"google-auth-library": "^10.5.0",
		"googleapis": "^171.1.0",
		"gsap": "^3.14.2",
		"hono": "^4.11.7",
		"hono-rate-limiter": "^0.5.3",
		"lucide-react": "^0.564.0",
		"motion": "^12.30.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.1",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"viem": "2.x",
		"wagmi": "^3.4.4",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"@tanstack/router-cli": "^1.160.0",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.9"
	}
}
