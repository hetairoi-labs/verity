{
	"name": "@verity/web",
	"version": "1.0.0",
	"type": "module",
	"main": "server.ts",
	"module": "server.ts",
	"scripts": {
		"dev": "clear && bun push && bun check && bun run --parallel tsr-watch dev:server",
		"dev:server": "bun --hot server.ts",
		"start": "tsr generate && NODE_ENV=production bun --env-file=.env.production run server.ts",
		"deploy": "./lib/scripts/deploy.sh",
		"build": "tsr generate && bun --env-file=.env.production run lib/build/index.ts",
		"tsc": "bunx --bun tsc --noEmit",
		"check": "bunx biome check --write",
		"generate": "bunx drizzle-kit generate",
		"migrate": "bunx drizzle-kit migrate",
		"push": "bunx drizzle-kit push",
		"test": "rm -f test.db && bun --env-file=.env.test run test:inner",
		"test:int": "INTEGRATION=true bun --env-file=.env.test run test:inner",
		"test:inner": "bun run push --force && bun test",
		"shadcn": "bunx --bun shadcn@latest add",
		"authenticate": "bun lib/utils/google.ts",
		"tsr-watch": "tsr watch"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@cerebras/cerebras_cloud_sdk": "^1.64.1",
		"@fontsource-variable/figtree": "^5.2.10",
		"@google/genai": "^1.42.0",
		"@hono/zod-validator": "^0.7.6",
		"@phosphor-icons/react": "^2.1.10",
		"@privy-io/node": "^0.9.0",
		"@privy-io/react-auth": "^3.14.1",
		"@privy-io/wagmi": "^4.0.2",
		"@sentry/react": "^10.40.0",
		"@tanstack/react-form": "^1.28.3",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.163.2",
		"axios": "^1.13.5",
		"better-sqlite3": "^12.6.2",
		"bun-plugin-tailwind": "^0.1.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"google-auth-library": "^10.6.1",
		"googleapis": "^171.4.0",
		"hono": "^4.12.2",
		"hono-rate-limiter": "^0.5.3",
		"hono-typedstream": "^0.1.3",
		"motion": "^12.34.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^3.8.5",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"viem": "^2.46.3",
		"wagmi": "^3.5.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@sentry/cli": "^3.2.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tanstack/router-cli": "^1.163.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.9"
	}
}
