{
	"name": "verity",
	"type": "module",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"check": "bunx biome check --write .",
		"purge": "./scripts/purge.sh",
		"contracts:compile": "bun run --filter @verity/contracts build",
		"contracts:test": "bun run --filter @verity/contracts test",
		"web:dev": "bun run --filter @verity/web dev",
		"web:test": "bun run --filter @verity/web test",
		"web:start": "bun run --filter @verity/web start",
		"web:build": "bun run --filter @verity/web build",
		"web:deploy": "bun run --filter @verity/web deploy"
	},
	"devDependencies": {
		"@types/node": "^25",
		"@biomejs/biome": "2.3.13",
		"@types/bun": "latest",
		"typescript": "^5"
	}
}
