{
  "name": "verity",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "viem": "^2.46.3"
  },
  "scripts": {
    "contracts:compile": "bun run --filter @verity/contracts build",
    "contracts:test": "bun run --filter @verity/contracts test",

    "dev": "bun run --filter @verity/web dev",
    "test": "bun run --filter @verity/web test",
    "deploy": "bun run --filter @verity/web deploy",

    "prepare": "husky",
    "check": "ultracite fix",
    "tsc": "clear && bunx --bun tsc --noEmit",
    "purge": "./scripts/purge.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "latest",
    "@types/node": "^25",
    "husky": "^9.1.7",
    "typescript": "^5",
    "ultracite": "7.2.4"
  }
}
